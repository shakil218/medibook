# Server
PORT=5000

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/medibook?retryWrites=true&w=majority

# Better Auth — generate with: openssl rand -base64 64
BETTER_AUTH_SECRET=your_better_auth_secret_here
BETTER_AUTH_URL=https://your-backend.vercel.app

# Frontend deployed URL (for CORS)
FRONTEND_URL=https://your-frontend.vercel.app

# AI Provider — Groq (FREE): https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# OpenAI (requires billing): https://platform.openai.com/billing
# OPENAI_API_KEY=your_openai_key_here

# Google OAuth — Create credentials at: https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: https://your-backend.vercel.app/api/auth/callback/google
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
